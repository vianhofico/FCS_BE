# Dev environment template
# Copy this file to .env for local docker compose usage.

# App
SPRING_PROFILES_ACTIVE=dev
APP_PORT=8080
JWT_SECRET=dev-secret-key-change-me
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# MySQL
MYSQL_PORT=3306
MYSQL_DATABASE=fashion_consignment_system
MYSQL_USER=sa
MYSQL_PASSWORD=123
MYSQL_ROOT_PASSWORD=root

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=5s

# MinIO
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=fcs-media
