## Spring profile
SPRING_PROFILES_ACTIVE=prod

## App runtime
APP_PORT=8080
JWT_SECRET=replace-with-a-long-random-secret
APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
APP_FRONTEND_BASE_URL=https://your-frontend-domain.com
OAUTH2_SUCCESS_REDIRECT_URI=https://your-frontend-domain.com/auth/oauth2/callback
OAUTH2_FAILURE_REDIRECT_URI=https://your-frontend-domain.com/auth/login
GOOGLE_REDIRECT_URI=https://your-frontend-domain.com/auth/oauth2/callback
GOOGLE_REDIRECT_URI=https://api.your-domain.com/login/oauth2/code/google

## MySQL
# MYSQL_PORT=3306
MYSQL_PORT=3307
MYSQL_DATABASE=fashion_consignment_system
MYSQL_USER=app_user
MYSQL_PASSWORD=replace-with-strong-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

## Redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_DATABASE=0
REDIS_TIMEOUT=5s

## MinIO
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=replace-with-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-minio-secret-key
MINIO_BUCKET=fcs-media
PAYOS_PAYMENT_TTL_MINUTES=15
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
OAUTH2_SUCCESS_REDIRECT_URI=https://your-frontend-domain.com/auth/oauth2/callback
OAUTH2_FAILURE_REDIRECT_URI=https://your-frontend-domain.com/auth/login
